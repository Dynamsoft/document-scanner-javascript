{
  "compilerOptions": {
    "baseUrl": ".", 
    "paths": {
      "dynamsoft-document-scanner": ["./dds/dds.bundle.d.ts"] 
    },
    "target": "es2017",
    "module": "esnext",
    "outDir": "dist",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "declaration": true,
    "declarationDir": "./types",
    "noImplicitAny": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts"
  ],    
  "exclude": [
    "node_modules/**"
  ]
}
