{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"projects": {
		"mds-angular": {
			"projectType": "application",
			"root": "",
			"sourceRoot": "src",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist",
						"index": "src/index.html",
						"browser": "src/main.ts",
						"tsConfig": "tsconfig.json",
						"assets": [
							{ "glob": "**/*", "input": "public" },
							{
								"glob": "**/*",
								"input": "node_modules/dynamsoft-document-scanner/dist",
								"output": "dynamsoft-document-scanner/dist"
							},
							{
								"glob": "**/*",
								"input": "node_modules/dynamsoft-capture-vision-bundle/dist",
								"output": "dynamsoft-capture-vision-bundle/dist"
							},
							{
								"glob": "**/*",
								"input": "node_modules/dynamsoft-capture-vision-data",
								"output": "dynamsoft-capture-vision-data"
							}
						],
						"styles": ["src/styles.css"]
					},
					"configurations": {
						"development": {
							"optimization": false,
							"sourceMap": true
						}
					}
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"options": {
						"host": "0.0.0.0",
						"ssl": true,
						"prebundle": {
							"exclude": [
								"dynamsoft-document-scanner",
								"dynamsoft-capture-vision-bundle",
								"dynamsoft-capture-vision-data"
							]
						}
					},
					"configurations": {
						"development": {
							"buildTarget": "mds-angular:build:development"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		}
	},
	"cli": {
		"analytics": false
	}
}
